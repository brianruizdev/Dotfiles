		"hyprland/window",
		"cpu",
		"memory",
		"disk"
	],
	"modules-center": [
		"hyprland/workspaces"
	],
	"modules-right": [
		"tray",
		"network",
		"pulseaudio",
		"battery",
		"clock",
		"custom/notification"
	],
	"custom/launcher": {
